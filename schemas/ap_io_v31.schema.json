{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AP/IO v3.1 Protocol Schema",
  "description": "JSON Schema for AP/IO v3.1 protocol messages",
  "type": "object",
  "required": ["protocol", "version", "agent", "ts", "event"],
  "properties": {
    "protocol": {
      "type": "string",
      "enum": ["AP/IO"],
      "description": "Protocol identifier"
    },
    "version": {
      "type": "string",
      "pattern": "^3\\.1$",
      "description": "Protocol version"
    },
    "agent": {
      "type": "string",
      "enum": ["cls", "andy", "hybrid", "liam", "gg", "kim"],
      "description": "Agent identifier"
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp (alternative to ts)"
    },
    "event": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["heartbeat", "task_start", "task_result", "error", "info", "routing_request", "correlation_query"]
        },
        "task_id": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": ["gg_orchestrator", "kim", "cursor", "launchd", "boss", "system"]
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "data": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "failure", "started", "in_progress", "error"]
        },
        "duration_sec": {
          "type": "number",
          "minimum": 0
        },
        "execution_duration_ms": {
          "type": "number",
          "minimum": 0,
          "description": "Execution duration in milliseconds"
        },
        "files_touched": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "routing": {
      "type": "object",
      "properties": {
        "targets": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["cls", "andy", "hybrid", "liam", "gg", "kim"]
          }
        },
        "broadcast": {
          "type": "boolean"
        },
        "priority": {
          "type": "string",
          "enum": ["critical", "high", "normal", "low"]
        }
      }
    }
  }
}
